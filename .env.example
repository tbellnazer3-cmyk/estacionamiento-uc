# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # "production" en producción

# ─── URLs (ajustar al dominio real en producción) ─────────────────────────────
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5500

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_URL=./database.sqlite    # En producción: ruta absoluta dentro del contenedor

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_muy_segura_aqui

# ─── Transbank / Webpay Plus ──────────────────────────────────────────────────
# Sandbox (integración) — valores por defecto en transbank.service.js
# Para producción: obtener en https://www.transbankdevelopers.cl
TRANSBANK_API_KEY=your_transbank_api_key
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_ENV=integration   # "production" para activar ambiente real

# ─── Correo / Notificaciones ─────────────────────────────────────────────────
# Gmail: activar verificación en 2 pasos y crear App Password
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password
EMAIL_FROM=EstacionaUC

# ─── SSO Institucional UC (pendiente de activación) ──────────────────────────
UC_SSO_CLIENT_ID=your_uc_sso_client_id
UC_SSO_SECRET=your_uc_sso_secret

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en ms
RATE_LIMIT_MAX=100           # máximo de peticiones por ventana
